node_modules/
.next/
.vercel/
.env*.local
.env
.venv/
*.log
**/.DS_Store
/coverage
/build

# Python artifacts (loader scripts, smoke tests)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Claude Code: ignore ephemeral and user-local state, keep shared config
.claude/worktrees/
.claude/settings.local.json
.claude/projects/

# Defense-in-depth: build-log lives in a sibling private repo, not here
build-log/

# Raw source dumps (Met CSV, AIC JSON dumps, Getty bulk exports). Large
# binary-ish files; keep out of git, re-fetch on demand from upstream.
data/

# Eval-harness regenerable artifacts (fetched images, computed embeddings).
# Re-derive with the harness's fetch_images.py + embed.py.
eval/**/images/
eval/**/*.npz
